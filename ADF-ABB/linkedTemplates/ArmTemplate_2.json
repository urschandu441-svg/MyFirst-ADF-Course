			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/DS_ADV_WORKS_SOURCE')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/pipeline_SSMS_Vault')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "Lookup1",
						"type": "Lookup",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"source": {
								"type": "SqlServerSource",
								"queryTimeout": "02:00:00",
								"partitionOption": "None"
							},
							"dataset": {
								"referenceName": "SSMS_Join",
								"type": "DatasetReference",
								"parameters": {}
