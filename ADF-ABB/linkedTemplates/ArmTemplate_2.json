										"type": "Expression"
									}
								}
							}
						}
					},
					{
						"name": "If_New_Record_Exists",
						"description": "if max value is null then initiate Full load or add only adding difference records",
						"type": "IfCondition",
						"dependsOn": [
							{
								"activity": "LKUP_Max_Value",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"userProperties": [],
						"typeProperties": {
							"expression": {
								"value": "@or(\n   equals(pipeline().parameters.LastLoadValue, null),\n   greater(\n       int(activity('LKUP_Max_Value').output.firstRow.MaxValue),\n       int(pipeline().parameters.LastLoadValue)\n   )\n)\n",
								"type": "Expression"
							},
							"ifTrueActivities": [
								{
									"name": "COPYSQL_FULL_INC_LOAD_TABLES",
