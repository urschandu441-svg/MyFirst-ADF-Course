									"dependsOn": [
										{
											"activity": "COPYSQL_FULL_INC_LOAD_TABLES",
											"dependencyConditions": [
												"Succeeded"
											]
										}
									],
									"policy": {
										"secureInput": false
									},
									"userProperties": [],
