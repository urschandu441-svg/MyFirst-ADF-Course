					},
					"LS_ADVWORKS_properties_typeProperties_database": {
						"value": "[parameters('LS_ADVWORKS_properties_typeProperties_database')]"
					},
					"LS_ADVWORKS_properties_typeProperties_userName": {
						"value": "[parameters('LS_ADVWORKS_properties_typeProperties_userName')]"
					},
					"LS_SSMS_SINK_properties_typeProperties_server": {
						"value": "[parameters('LS_SSMS_SINK_properties_typeProperties_server')]"
					},
					"LS_SSMS_SINK_properties_typeProperties_database": {
						"value": "[parameters('LS_SSMS_SINK_properties_typeProperties_database')]"
					},
					"LS_SSMS_SINK_properties_typeProperties_userName": {
						"value": "[parameters('LS_SSMS_SINK_properties_typeProperties_userName')]"
					},
					"SqlServer1_properties_typeProperties_server": {
						"value": "[parameters('SqlServer1_properties_typeProperties_server')]"
					},
					"SqlServer1_properties_typeProperties_database": {
						"value": "[parameters('SqlServer1_properties_typeProperties_database')]"
					},
					"SqlServer1_properties_typeProperties_userName": {
						"value": "[parameters('SqlServer1_properties_typeProperties_userName')]"
