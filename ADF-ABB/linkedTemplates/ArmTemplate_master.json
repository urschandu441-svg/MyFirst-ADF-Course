		"LS_SSMS_SINK_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SSMS_SINK'"
		},
		"LinkService_DL_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LinkService_DL'"
		},
		"SqlServer1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SqlServer1'"
