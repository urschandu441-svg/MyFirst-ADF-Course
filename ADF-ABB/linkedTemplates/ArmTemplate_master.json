		"LS_ADVWORKS_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "chandu441"
		},
		"LS_RestResource_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://retoolapi.dev/5yDVOt/data"
		},
		"LS_SSMS_SINK_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "DESKTOP-U35BAFM\\SQLEXPRESS"
		},
		"LS_SSMS_SINK_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "VisionBoardDataMigration"
		},
		"LS_SSMS_SINK_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "chandu441"
		},
